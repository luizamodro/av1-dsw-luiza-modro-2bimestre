generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tarefa {
  id        Int     @id @default(autoincrement())
  descricao String
  concluida Boolean @default(false)
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("tarefas")
}
